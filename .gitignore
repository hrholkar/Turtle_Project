# ========================
# TurtleTrack .gitignore
# ========================

# ── Environment ──────────────────────────────────────
.env
.env.local
.env.production
.env.staging

# ── Node / Backend ───────────────────────────────────
node_modules/
dist/
build/
*.js.map
*.d.ts.map
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm
.pnpm-store

# ── Python / ML Service ───────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
pip-log.txt
pip-delete-this-directory.txt
*.egg-info/
.eggs/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
*.cover

# ── ML Artifacts ──────────────────────────────────────
backend-ml/storage/embeddings/
backend-ml/storage/index/
*.index
*.pkl
*.pt
*.pth

# ── Uploads (local storage) ────────────────────────────
uploads/turtles/*
uploads/sightings/*
uploads/temporary/*
!uploads/turtles/.gitkeep
!uploads/sightings/.gitkeep
!uploads/temporary/.gitkeep

# ── Expo / React Native ───────────────────────────────
frontend/.expo/
frontend/node_modules/
frontend/dist/
frontend/web-build/
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.orig.*

# ── IDEs ─────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Logs ─────────────────────────────────────────────
logs/
*.log

# Dataset
dataset/

# MongoDB Atlas migration scripts
backend-node/checkMigrationState.js
backend-node/performMigration.js
backend-node/testAtlas.js
backend-node/testTLS.js
backend-node/transfer.js