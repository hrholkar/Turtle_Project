{
  "expo": {
    "name": "TurtleTrack",
    "slug": "turtletrack",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B1929"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.turtletrack.app",
      "infoPlist": {
        "NSCameraUsageDescription": "TurtleTrack needs camera access to photograph sea turtles for identification.",
        "NSPhotoLibraryUsageDescription": "TurtleTrack needs photo library access to select turtle images.",
        "NSLocationWhenInUseUsageDescription": "TurtleTrack uses your location to record sighting coordinates."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B1929"
      },
      "package": "com.turtletrack.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      [
        "expo-image-picker",
        {
          "photosPermission": "TurtleTrack uses photos to identify sea turtles.",
          "cameraPermission": "TurtleTrack uses your camera to photograph sea turtles."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "TurtleTrack records sighting locations."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ],
    "scheme": "turtletrack",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4734b924-373f-4745-96e3-3f28ad5067b0"
      }
    }
  }
}
