# ============================================================
# TurtleTrack — Environment Variables Reference
# Copy this file to .env and fill in your values
# ============================================================

# ── Node Backend ─────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/turtletrack

# ML Service URL (Python FastAPI)
ML_SERVICE_URL=http://localhost:8000

# Upload directory (absolute or relative to backend-node/)
UPLOAD_DIR=../uploads

# Max upload file size in bytes (default 10MB)
MAX_FILE_SIZE=10485760

# Allowed image MIME types (comma-separated)
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp

# CORS origin for frontend dev
CORS_ORIGIN=*

# ── Python ML Service ─────────────────────────────────────────
ML_PORT=8000
ML_HOST=0.0.0.0
ML_WORKERS=1

# Upload dir visible to ML service
ML_UPLOAD_DIR=../uploads

# FAISS index persistence path
FAISS_INDEX_PATH=./storage/index/turtles.index
FAISS_ID_MAP_PATH=./storage/index/id_map.json

# Feature extraction model
ML_MODEL_NAME=mobilenet_v2
ML_EMBEDDING_DIM=1280

# Similarity thresholds
MATCH_THRESHOLD_HIGH=0.85
MATCH_THRESHOLD_LOW=0.65

# Max results returned from similarity search
ML_TOP_K=5

# ── Storage Adapter ───────────────────────────────────────────
# Set to "local" (default) or "s3" (requires S3 config below)
STORAGE_ADAPTER=local

# ── S3 Storage (future / stub) ────────────────────────────────
S3_BUCKET_NAME=turtletrack-uploads
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=your_access_key
S3_SECRET_ACCESS_KEY=your_secret_key
S3_ENDPOINT_URL=

# ── MongoDB Docker ────────────────────────────────────────────
MONGO_INITDB_DATABASE=turtletrack
